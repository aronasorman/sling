[project]
client = "eclub"
remote = "github"
issue_source = "github"        # "linear", "github", or "auto"
linear_team = "ENG"            # if using Linear
# github_repo auto-detected from git remote

[execution]
max_attempts = 3
review_max_rounds = 3
# Optional: shell commands run in the epic worktree after the executor finishes.
# If omitted, sling auto-detects Go projects (go build ./... + go test ./...).
# build_cmd = "go build ./..."
# test_cmd  = "go test -count=1 ./..."

[context]
conventions = "docs/CONVENTIONS.md"
tech_stack = "docs/TECH_STACK.md"
agent_instructions = "AGENTS.md"

[notifications]
telegram_enabled = true
telegram_chat_id = ""
